{
  "version": 2,
  "builds": [
    {
      "src": "whiteboard-tutorial/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    { "src": "backend/server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/(.*)", "dest": "whiteboard-tutorial/build/$1" }
  ]
}
